{
  "name": "music-app-react-lite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm:dev:web:wait\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:web:wait": "wait-on http-get://127.0.0.1:5174/api/health && npm run dev:web",
    "dev:server": "npm --prefix server run dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.js"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  }
}
